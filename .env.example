# Server
PORT=3000
NODE_ENV=development

# MongoDB Atlas — get the SRV string from Atlas > Connect > Drivers
MONGO_URI=

# Auth
# JWT_SECRET: generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Frontend origin (CORS + cookie); Vite dev default is 5173
FRONTEND_URL=http://localhost:5173

# Google sign-in — OAuth 2.0 Web client ID from Google Cloud Console (Credentials)
# Leave empty to disable Google sign-in (the /auth/google route returns 503).
GOOGLE_CLIENT_ID=

# Gemini (vision + chat + copilot)
GEMINI_API_KEY=
# Model to use. flash-lite has the highest free-tier daily limit (RPD).
GEMINI_MODEL=gemini-2.5-flash-lite

# Composio — lets Penny email an invoice summary via your connected Gmail.
# Get a key at https://app.composio.dev, then connect Gmail for COMPOSIO_USER_ID
# (e.g. `composio add gmail`). Leave empty to disable the email_summary tool.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=default
